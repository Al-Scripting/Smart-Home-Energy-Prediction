      "source": [
        "### Raspberry Pi Metrics\n",
        "\n",
        "| Model             | MAE | RMSE | R2 | Training Time (ms) | Testing Time (ms) |\n",
        "|-------------------|-----|------|----|--------------------|-------------------|\n",
        "| Linear Regression |     |      |    |                    |                   |\n",
        "| Random Forest     |     |      |    |                    |                   |\n",
        "| XGBoost           |     |      |    |                    |                   |\n",
        "\n"
      ]
    },
